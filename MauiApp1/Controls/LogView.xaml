<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="Root"
             x:Class="MauiApp1.Controls.LogView">
    <Border
        Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
        StrokeThickness="1"
        Padding="0"
        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}">
        <Grid RowDefinitions="Auto,*">
            <Grid
                Padding="10,8"
                ColumnDefinitions="*,Auto,Auto,Auto"
                ColumnSpacing="8"
                BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#1F2937}">
                <Label
                    Text="{Binding StatusText, Source={x:Reference Root}}"
                    FontAttributes="Bold"
                    FontSize="13"
                    LineBreakMode="TailTruncation"
                    VerticalOptions="Center"
                    TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />

                <Button
                    Grid.Column="1"
                    Text="Start"
                    Padding="10,4"
                    MinimumHeightRequest="32"
                    IsEnabled="{Binding IsStartEnabled, Source={x:Reference Root}}"
                    Clicked="OnStartClicked" />

                <Button
                    Grid.Column="2"
                    Text="Stop"
                    Padding="10,4"
                    MinimumHeightRequest="32"
                    IsEnabled="{Binding IsStopEnabled, Source={x:Reference Root}}"
                    Clicked="OnStopClicked" />

                <Button
                    Grid.Column="3"
                    Text="Clear"
                    Padding="10,4"
                    MinimumHeightRequest="32"
                    Clicked="OnClearClicked" />
            </Grid>

            <CollectionView
                x:Name="LogEntriesView"
                Grid.Row="1"
                ItemsSource="{Binding Entries, Source={x:Reference Root}}"
                SelectionMode="None">
                <CollectionView.EmptyView>
                    <Grid Padding="14">
                        <Label
                            Text="No log entries yet."
                            TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                    </Grid>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label
                            Padding="12,4"
                            FontFamily="Consolas"
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            Text="{Binding .}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Border>
</ContentView>
